APP_NAME=RPD
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID
APP_TIMEZONE=Asia/Jakarta

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=rpd
DB_USERNAME=postgres
DB_PASSWORD=postgres

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database

CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@rpd.local"
MAIL_FROM_NAME="${APP_NAME}"

# WhatsApp OTP delivery configuration.
# When WHATSAPP_OTP_ENABLED=false or provider=log the OTP is written to the
# log file (storage/logs/laravel.log) and the app stays fully runnable.
WHATSAPP_OTP_ENABLED=false
WHATSAPP_OTP_PROVIDER=log
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=
WHATSAPP_SENDER=
WHATSAPP_OTP_TTL=5

VITE_APP_NAME="${APP_NAME}"


# AutoGoPay (QRIS payment gateway)
# Isi API key di server saja (.env), JANGAN commit / sebar.
AUTOGOPAY_BASE_URL=https://v1-gateway.autogopay.site
AUTOGOPAY_API_KEY=
